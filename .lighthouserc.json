{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000/"],
      "startServerCommand": "cd server && ADMIN_PIN=ci-pin JWT_SECRET=ci-secret-do-not-use DB_URL=:memory: node index.js",
      "startServerReadyPattern": "Server running on",
      "startServerReadyTimeout": 30000,
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "audits:installable-manifest": ["error", { "minScore": 1 }],
        "audits:service-worker": ["error", { "minScore": 1 }],
        "audits:maskable-icon": ["warn", { "minScore": 1 }],
        "audits:apple-touch-icon": ["warn", { "minScore": 1 }],
        "audits:themed-omnibox": ["warn", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
