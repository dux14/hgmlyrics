# Frontend (Vite expone vars prefijadas con VITE_) — públicas, OK commitear este archivo.
VITE_SUPABASE_URL=https://omntufksfhezqtqgmhlp.supabase.co
VITE_SUPABASE_ANON_KEY=<paste-anon-key-from-supabase-dashboard>
# Google OAuth client ID (web) para "Guardar en Drive" del Estudio (público, no secreto)
VITE_GOOGLE_CLIENT_ID=

# Mundo virtual — WebRTC voz por zona (STUN es gratis; TURN es opcional para NAT simétrico)
# Si VITE_TURN_URL está vacío solo se usan los STUN públicos de Google.
# Formato: turn:<host>:<puerto>  o  turns:<host>:<puerto>  (TLS)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Backend (Vercel Functions) — no commitear valores reales en otros archivos.
SUPABASE_URL=https://omntufksfhezqtqgmhlp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key>
DATABASE_URL=<paste-postgres-connection-string>

# Admin gating — CSV de emails que se promueven a admin en cada login.
ADMIN_EMAILS=sduqueporras5@gmail.com

# Estudio de pistas (separación de stems/voces) — procesado en Replicate.
REPLICATE_API_TOKEN=<paste-replicate-api-token>
# Secreto de firma de webhooks de Replicate (GET /v1/webhooks/default/secret → "whsec_...").
REPLICATE_WEBHOOK_SECRET=<paste-replicate-webhook-secret>
# Secreto para autorizar el cron de limpieza (Vercel inyecta el header Authorization: Bearer).
CRON_SECRET=<generar-token-aleatorio>
# Base pública del despliegue (para construir las URLs de webhook de Replicate).
PUBLIC_BASE_URL=https://hgmlyrics.vercel.app
