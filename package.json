{
  "name": "hgmlyrics",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{js,css,html,json}'",
    "format:check": "prettier --check 'src/**/*.{js,css,html,json}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,css,html,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@lhci/cli": "^0.13.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "flexsearch": "^0.8.212",
    "idb-keyval": "^6.2.2"
  }
}
