{
  "name": "hgmlyrics",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{js,css,html,json}'",
    "format:check": "prettier --check 'src/**/*.{js,css,html,json}'",
    "optimize:covers": "node scripts/optimize-covers.mjs",
    "dev:vercel": "vercel dev --listen 3000",
    "test:e2e:offline": "pnpm build && start-server-and-test 'pnpm preview --port 4173' http://localhost:4173 'playwright test e2e/offline.spec.js'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,css,html,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "pdfjs-dist": "^6.0.227",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^3.0.11",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "fflate": "^0.8.3",
    "flexsearch": "^0.8.212",
    "formidable": "^3.5.4",
    "idb-keyval": "^6.2.2",
    "phaser": "^4.1.0",
    "postgres": "^3.4.9"
  }
}
